# Required
POSTGRES_PASSWORD=changeme
JWT_SECRET=your-jwt-secret-min-32-characters-long
GOTRUE_SERVICE_ROLE_KEY=your-service-role-key
FORUM_DOMAIN=forum.example.com
SITE_URL=https://forum.example.com

# Forum name (shown in UI)
FORUM_NAME=My Forum

# Host port mapping (default 3000)
HOST_PORT=3000

# Email (optional — without SMTP, auto-confirm is enabled)
MAILER_AUTOCONFIRM=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Forumline network integration (optional)
FORUMLINE_APP_URL=
FORUMLINE_CLIENT_ID=
FORUMLINE_CLIENT_SECRET=
FORUMLINE_JWT_SECRET=
FORUMLINE_GOTRUE_URL=
FORUMLINE_SERVICE_ROLE_KEY=

# LiveKit voice rooms (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Cloudflare R2 avatar storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
