# Required
POSTGRES_PASSWORD=changeme
FORUM_DOMAIN=forum.example.com
SITE_URL=https://forum.example.com

# Forum name (shown in UI)
FORUM_NAME=My Forum

# Host port mapping (default 3000)
HOST_PORT=3000

# Forumline identity (required — register your forum at app.forumline.net)
FORUMLINE_APP_URL=https://app.forumline.net
FORUMLINE_CLIENT_ID=
FORUMLINE_CLIENT_SECRET=
FORUMLINE_JWT_SECRET=

# LiveKit voice rooms (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Cloudflare R2 avatar storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
